
        System.out.println("\nAdd-On Services for Reservation ID: " + reservationId);
        System.out.println("----------------------------------------");

        for (AddOnService service : services) {
            service.display();
        }

        System.out.println("Total Add-On Cost: ₹" + calculateTotalServiceCost(reservationId));
    }
}

